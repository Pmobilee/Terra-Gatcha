{
  "name": "recall-rogue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/gen-sprite-keys.mjs && node scripts/build-facts-db.mjs && vite",
    "webp": "node scripts/convert-to-webp.mjs",
    "prebuild": "node scripts/audit-fact-sprites.mjs --emit-manifest && node scripts/convert-to-webp.mjs",
    "build": "node scripts/gen-sprite-keys.mjs && node scripts/audit-assets.mjs && node scripts/build-facts-db.mjs && vite build",
    "audit:sprites": "node scripts/audit-fact-sprites.mjs",
    "audit:sprites:ci": "node scripts/audit-fact-sprites.mjs --fail-below=80",
    "build:facts": "node scripts/build-facts-db.mjs",
    "content:ingest": "node scripts/ingest-facts.mjs",
    "content:coverage": "node scripts/report-coverage.mjs",
    "content:verify": "node scripts/verify-facts.mjs",
    "content:vocab:build": "node scripts/content-pipeline/vocab/build-seed-packs.mjs",
    "content:vocab:validate": "node scripts/content-pipeline/vocab/validate-seed-packs.mjs",
    "content:source-mix": "node scripts/content-pipeline/manual-ingest/source-mix.mjs",
    "content:workers:prepare": "node scripts/content-pipeline/agent-workers.mjs prepare",
    "content:workers:ingest": "node scripts/content-pipeline/agent-workers.mjs ingest",
    "content:workers:qa": "node scripts/content-pipeline/agent-workers.mjs qa",
    "content:workers:promote": "node scripts/content-pipeline/agent-workers.mjs promote",
    "content:workers:status": "node scripts/content-pipeline/agent-workers.mjs status",
    "content:workers:all": "node scripts/content-pipeline/agent-workers.mjs all",
    "content:subcategory:backfill:llm": "node scripts/content-pipeline/llm-backfill-subcategories.mjs",
    "content:visuals:fill": "node scripts/content-pipeline/fill-missing-visual-descriptions.mjs",
    "content:autopilot": "node scripts/content-pipeline/autopilot.mjs",
    "content:generate:all": "node scripts/content-pipeline/generate/generate-all-domains.mjs",
    "simulate:fsrs": "npx tsx scripts/fsrs-simulate.ts --accuracy 0.7 --days 180 --seed 42",
    "simulate:fsrs-sweep": "npx tsx scripts/fsrs-simulate.ts --sweep --days 90",
    "simulate:mass": "npx tsx scripts/mass-simulate.ts",
    "simulate:deep": "npx tsx scripts/mass-simulate.ts --mode deep --seeds 100",
    "simulate:economy": "npx tsx scripts/economy-simulate.ts --profiles average,expert --max-runs 500",
    "simulate:all": "npm run simulate:deep && npm run simulate:fsrs && npm run simulate:economy",
    "balance:sanity": "npx tsx scripts/balance-battery.ts --battery sanity",
    "balance:sweep": "npx tsx scripts/balance-battery.ts --battery full-sweep",
    "balance:combos": "npx tsx scripts/balance-battery.ts --battery deep-combos",
    "balance:stress": "npx tsx scripts/balance-battery.ts --battery ascension-stress",
    "balance:fairness": "npx tsx scripts/balance-battery.ts --battery fairness-audit",
    "balance:baseline": "npx tsx scripts/balance-battery.ts --set-baseline",
    "balance:deep": "npx tsx scripts/balance-battery.ts --battery deep-combat",
    "balance:fsrs": "npx tsx scripts/balance-battery.ts --battery fsrs-progression",
    "balance:economy": "npx tsx scripts/balance-battery.ts --battery economy-progression",
    "balance:full-audit": "npx tsx scripts/balance-battery.ts --battery full-audit",
    "balance:diff": "npx tsx scripts/balance-battery.ts --diff",
    "content:factcheck": "node scripts/content-pipeline/qa/source-fact-check.mjs",
    "content:qa": "node scripts/content-pipeline/qa/run-post-generation-qa.mjs",
    "content:qa:gameplay": "node scripts/content-pipeline/qa/gameplay-safety-check.mjs",
    "content:qa:answer-check:workers": "node scripts/content-pipeline/qa/answer-check-worker-batches.mjs",
    "content:qa:answer-check:db": "node scripts/content-pipeline/qa/answer-check-live-db.mjs",
    "content:qa:fix:llm": "node scripts/content-pipeline/qa/llm-fact-quality-fix.mjs run-all",
    "content:qa:fix:llm:distractors": "node scripts/content-pipeline/qa/llm-fact-quality-fix.mjs distractors",
    "content:qa:id-gate": "node scripts/content-pipeline/qa/id-collision-gate.mjs --strict",
    "content:qa:gate": "node scripts/content-pipeline/qa/post-ingestion-gate.mjs",
    "content:qa:sweep": "node scripts/content-pipeline/qa/quality-sweep-db.mjs",
    "content:coverage:gate": "node scripts/content-pipeline/qa/coverage-gate.mjs",
    "content:promote": "node scripts/content-pipeline/qa/promote-approved-to-db.mjs",
    "content:manual:validate": "node scripts/content-pipeline/manual-ingest/run.mjs validate",
    "content:manual:dedup": "node scripts/content-pipeline/manual-ingest/run.mjs dedup",
    "content:manual:preview": "node scripts/content-pipeline/manual-ingest/run.mjs merge-preview",
    "content:manual:finalize": "node scripts/content-pipeline/manual-ingest/run.mjs finalize",
    "content:manual:full": "node scripts/content-pipeline/manual-ingest/run.mjs full",
    "content:manual:review": "node scripts/content-pipeline/manual-ingest/review-server.mjs",
    "content:manual:build-index": "node scripts/content-pipeline/manual-ingest/run.mjs build-index",
    "camp:art:prepare": "node scripts/camp-art/pipeline.mjs prepare",
    "camp:art:ingest": "node scripts/camp-art/pipeline.mjs ingest",
    "camp:art:manifest": "node scripts/camp-art/pipeline.mjs manifest",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.app.json",
    "lint": "eslint src/ --ext .ts,.svelte",
    "audit": "npm audit --audit-level=moderate",
    "audit:assets": "node scripts/audit-assets.mjs",
    "audit:assets:strict": "node scripts/audit-assets.mjs --strict",
    "simulate": "node scripts/simulate-balance.mjs",
    "playtest:dashboard": "node sprite-gen/cardback-tool/server.mjs",
    "playtest:campaign": "node scripts/playtest-campaign.mjs",
    "playtest:campaign:smoke": "node scripts/playtest-campaign.mjs --runs 10 --parallel 5 --campaign-id smoke-campaign --seed-base 91000",
    "playtest:leaderboard:validate": "node scripts/validate-playtest-leaderboard.mjs",
    "test": "vitest run",
    "test:unit:critical": "vitest run tests/unit/run-manager.test.ts tests/unit/encounter-engine.test.ts tests/unit/deckManager.hotfix.test.ts tests/unit/ascension.test.ts tests/unit/runSaveService.test.ts tests/unit/dailyExpeditionService.test.ts tests/unit/endlessDepthsService.test.ts tests/unit/scholarChallengeService.test.ts tests/unit/scoreSubmissionQueue.test.ts",
    "test:e2e:critical": "playwright test tests/e2e/playwright/app-loads.spec.ts tests/e2e/playwright/hub-navigation.spec.ts tests/e2e/playwright/card-play-flow.spec.ts tests/e2e/playwright/ascension-flow.spec.ts",
    "verify:release-gate": "node scripts/verify-release-gate.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "audit:perf": "node tests/e2e/performance-audit.mjs",
    "build:check": "npm run build && node scripts/check-bundle-size.mjs",
    "deploy:preview": "npm run build && npx wrangler pages deploy dist --project-name recall-rogue --branch preview",
    "deploy:production": "npm run build && npx wrangler pages deploy dist --project-name recall-rogue --branch main",
    "i18n:validate": "node src/i18n/scripts/validate-locale.mjs",
    "i18n:export-facts": "node src/i18n/scripts/export-facts-for-translation.mjs",
    "analyze": "ANALYZE=true npm run build",
    "postinstall": "cp node_modules/sql.js/dist/sql-wasm.wasm public/sql-wasm.wasm",
    "verify:stability": "node scripts/critical-loop.mjs",
    "security:audit": "node scripts/security-audit.mjs",
    "verify:ship": "node scripts/verify-ship.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.3.1",
    "happy-dom": "^14.12.3",
    "playwright-core": "^1.58.2",
    "sharp": "^0.34.5",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "better-sqlite3": "^12.6.2",
    "phaser": "^3.90.0",
    "sql.js": "^1.14.1",
    "ts-fsrs": "^5.2.3"
  },
  "overrides": {
    "tar": "7.5.11"
  }
}
