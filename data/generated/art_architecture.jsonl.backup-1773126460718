{"id": "art-oude-kerk-069", "type": "fact", "statement": "The Oude Kerk (Old Church) is Amsterdam's oldest building and oldest parish church, consecrated around 1306.", "explanation": "Construction began around 1300, making it older than the city's formal charter. The church features remarkable medieval wooden ceiling paintings and Europe's largest medieval wooden vault. Today it serves as both a place of worship and a contemporary art exhibition space.", "wowFactor": "Amsterdam's oldest building doubles as a cutting-edge contemporary art gallery inside a medieval church!", "quizQuestion": "What is Amsterdam's oldest building?", "correctAnswer": "Oude Kerk", "distractors": [{"text": "Nieuwe Kerk", "difficultyTier": "easy"}, {"text": "Royal Palace", "difficultyTier": "easy"}, {"text": "Anne Frank House", "difficultyTier": "easy"}, {"text": "Westerkerk", "difficultyTier": "medium"}, {"text": "Dam Square Tower", "difficultyTier": "medium"}, {"text": "Waag", "difficultyTier": "medium"}, {"text": "Begijnhof Chapel", "difficultyTier": "hard"}, {"text": "Montelbaanstoren", "difficultyTier": "hard"}], "variants": [{"question": "What is Amsterdam's oldest parish church?", "type": "forward", "correctAnswer": "Oude Kerk", "distractors": ["Nieuwe Kerk", "Westerkerk", "Noorderkerk"]}, {"question": "Which Amsterdam landmark has Europe's largest medieval wooden vault?", "type": "reverse", "correctAnswer": "Oude Kerk", "distractors": ["Nieuwe Kerk", "Royal Palace", "Rijksmuseum"]}, {"question": "The Oude Kerk is NOT used for which purpose today?", "type": "negative", "correctAnswer": "Royal residence", "distractors": ["Worship", "Art exhibitions", "Cultural events"]}, {"question": "The Oude Kerk means _____ Church in Dutch.", "type": "fill_blank", "correctAnswer": "Old", "distractors": ["New", "Great", "Royal"]}, {"question": "The Oude Kerk is Amsterdam's oldest surviving building.", "type": "true_false", "correctAnswer": "True", "distractors": ["False"]}], "difficulty": 2, "funSco