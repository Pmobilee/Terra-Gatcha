<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Distribution method for App Store upload -->
  <key>method</key>
  <string>app-store-connect</string>

  <!-- Your Apple Developer team ID — replace with actual Team ID from developer.apple.com -->
  <key>teamID</key>
  <string>YOUR_TEAM_ID</string>

  <!-- Bitcode upload disabled (deprecated by Apple as of Xcode 14) -->
  <key>uploadBitcode</key>
  <false/>

  <!-- Upload dSYM files for symbolicated crash reports in App Store Connect -->
  <key>uploadSymbols</key>
  <true/>

  <!-- Manual signing uses the provisioning profile explicitly configured below -->
  <key>signingStyle</key>
  <string>manual</string>

  <!-- The signing certificate to use for distribution -->
  <key>signingCertificate</key>
  <string>Apple Distribution</string>

  <!-- Map bundle ID to the provisioning profile name installed in Xcode -->
  <key>provisioningProfiles</key>
  <dict>
    <key>com.terragacha.app</key>
    <string>Terra Gacha App Store</string>
  </dict>
</dict>
</plist>
