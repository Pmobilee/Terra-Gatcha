# Terra Gacha Server — Environment Variables
# Copy this file to .env and fill in values before running

# Server
PORT=3001
NODE_ENV=development

# JWT Authentication
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# Database
# SQLite (development): relative path to .db file
# PostgreSQL (production): postgres://user:pass@host:5432/dbname
DATABASE_URL=./data/terra-gacha.db

# CORS — allowed origin(s) for the frontend
CORS_ORIGIN=http://localhost:5173
