# server/.env.example — copy to .env and fill in real values
# NEVER commit the .env file with actual secrets.

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=change-me-minimum-64-chars-random-string-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d
DATABASE_URL=postgresql://user:password@localhost:5432/terra_gacha
CORS_ORIGIN=https://terra-gacha.app
ADMIN_API_KEY=change-me-admin-key

# ── Content pipeline ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
COMFYUI_URL=http://localhost:8188
DISTRACTOR_CONFIDENCE_THRESHOLD=0.7

# ── Monetisation (RevenueCat) ─────────────────────────────────────────────────
# RevenueCat server API key (from RevenueCat dashboard → API Keys → Secret keys)
REVENUECAT_API_KEY=appl_...
# S2S webhook shared secret (from RevenueCat dashboard → Integrations → Webhooks)
REVENUECAT_WEBHOOK_SECRET=rc_whsec_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from https://resend.com — no SMTP config needed
RESEND_API_KEY=re_...
FROM_EMAIL=GAIA <gaia@terra-gacha.app>
PASSWORD_RESET_BASE_URL=https://terra-gacha.app/reset-password
EMAIL_UNSUBSCRIBE_BASE_URL=https://terra-gacha.app/api/email/unsubscribe

# ── Push Notifications (FCM) ──────────────────────────────────────────────────
# Values from Firebase Console → Project Settings → Service Accounts → Generate new key
FCM_PROJECT_ID=terra-gacha-12345
FCM_CLIENT_EMAIL=firebase-adminsdk@terra-gacha-12345.iam.gserviceaccount.com
# Newlines in the key must be literal \n in the .env value
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ── TTS (Azure Cognitive Services) ───────────────────────────────────────────
# From Azure Portal → Cognitive Services → Speech resource → Keys and Endpoint
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=eastus

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# ── Admin Dashboard (Basic Auth for /admin HTML routes) ───────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
