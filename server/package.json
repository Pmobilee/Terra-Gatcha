{
  "name": "terra-gacha-server",
  "version": "1.0.0",
  "description": "Fastify + TypeScript backend API for Terra Gacha mobile game",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit",
    "dashboard": "tsx src/dashboard/index.ts",
    "sprite-daemon": "tsx src/scripts/sprite-gen-daemon.ts",
    "pipeline": "tsx src/workers/pipelineWorker.ts",
    "generate-batch": "tsx src/scripts/generate-batch.ts",
    "expand-distractors": "tsx src/scripts/expand-distractors.ts",
    "release-bundle": "tsx src/scripts/release-bundle.ts",
    "smoke-test": "npx tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "fastify": "^5.7.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.21.4",
    "supertest": "^7.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
