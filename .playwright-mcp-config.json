{
  "browser": {
    "browserName": "chromium",
    "executablePath": "/opt/google/chrome/chrome",
    "launchOptions": {
      "chromiumSandbox": false,
      "args": ["--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage"]
    },
    "contextOptions": {
      "viewport": { "width": 1280, "height": 720 }
    }
  }
}
